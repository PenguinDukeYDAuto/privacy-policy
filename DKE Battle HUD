<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy Policy - DKE战斗座舱</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.8;
      color: #333;
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 20px;
      background: #fafafa;
    }
    h1 { font-size: 1.8em; margin-bottom: 8px; color: #111; }
    h2 { font-size: 1.2em; margin-top: 28px; margin-bottom: 8px; color: #222; }
    p { margin-bottom: 12px; }
    .date { color: #888; font-size: 0.9em; margin-bottom: 32px; }
    .lang-switch {
      text-align: right;
      margin-bottom: 20px;
    }
    .lang-switch a {
      color: #0066cc;
      text-decoration: none;
      cursor: pointer;
      padding: 4px 12px;
      border: 1px solid #0066cc;
      border-radius: 4px;
      font-size: 0.9em;
    }
    .lang-switch a:hover { background: #0066cc; color: #fff; }
    section { display: none; }
    section.active { display: block; }
    hr { border: none; border-top: 1px solid #ddd; margin: 32px 0; }
    a { color: #0066cc; }
  </style>
</head>
<body>

<div class="lang-switch">
  <a onclick="switchLang('en')">English</a>
  <a onclick="switchLang('zh')">中文</a>
</div>

